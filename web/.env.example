# ── RobinShare (FLEDGE) web env ─────────────────────────────────────────────
# PUBLIC (se exponen al browser, prefijo NEXT_PUBLIC_):
NEXT_PUBLIC_FACTORY_ADDRESS=0x        # la SocialFeeEscrowFactory desplegada en 4663 (output del
                                      # `forge script script/Deploy.s.sol` — ver docs/RUNBOOK-launch.md paso 1)
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# NEXT_PUBLIC_DIRECTION — opcional, NO seteés esto en prod. Sin definir, cae a "legend"
# (ganadora del bake-off 2026-07-13, identidad oficial de RobinShare). Solo sirve para forzar
# otra dirección de arte archivada (sky/nest/avion/sherwood/hood/decree/terminal/manga) en un
# preview branch de Vercel — todas siguen navegables en prod vía /v/<dir> sin tocar esta var.
# NEXT_PUBLIC_DIRECTION=legend

# SECRETOS (SOLO server — nunca prefijo NEXT_PUBLIC_):
ATTESTER_PK=0x                        # PK de una wallet NUEVA y dedicada (sin fondos). Su ADDRESS
                                      # debe ser la que se le pasó a la factory como attester
                                      # canónico (ATTESTER_ADDRESS en docs/RUNBOOK-launch.md paso 0/1).
                                      # Si no coincide, GET /api/health devuelve attesterMatches:false
                                      # y TODO claim de github/X revierte.
ATTESTER_STATE_SECRET=                # string aleatorio largo (firma el state del OAuth de GitHub).
                                      # generalo con: openssl rand -hex 32
GITHUB_CLIENT_ID=                     # GitHub OAuth App — github.com/settings/developers → New OAuth App
GITHUB_CLIENT_SECRET=                 # callback exacto: <APP_BASE_URL>/api/attest/github/callback
# Twitter/X: NO requiere env — usa el oráculo público de Flap (XGeneralVerifier en
# verifyx.taxed.fun, ya live en Robinhood Chain/4663). Reclaim quedó reemplazado por este oráculo.

# Dominio público de la app, EXACTO (para armar el redirect del OAuth de GitHub):
APP_BASE_URL=http://localhost:3000
